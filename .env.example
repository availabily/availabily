# ─── Demo mode ───────────────────────────────────────────────────────────────
# Set to "true" to run without Supabase or Infobip.
# Uses in-memory data (resets on server restart). Visit /demo to preview.
NEXT_PUBLIC_DEMO_MODE=true

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Infobip ──────────────────────────────────────────────────────────────────
INFOBIP_API_KEY=
INFOBIP_API_BASE_URL=

# ─── Resend (email delivery) ──────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@amorpm.com

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://amorpm.com
