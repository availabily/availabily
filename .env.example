# ─── Demo mode ───────────────────────────────────────────────────────────────
# Set to "true" to run without Supabase or Infobip.
# Uses in-memory data (resets on server restart). Visit /demo to preview.
NEXT_PUBLIC_DEMO_MODE=true

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Resend (email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Session ──────────────────────────────────────────────────────────────────
# A long random secret for signing session tokens. Generate with: openssl rand -hex 32
SESSION_SECRET=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://amorpm.com
