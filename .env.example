# ─── Demo mode ───────────────────────────────────────────────────────────────
# Set to "true" to run without Supabase or Infobip.
# Uses in-memory data (resets on server restart). Visit /demo to preview.
NEXT_PUBLIC_DEMO_MODE=true

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Infobip (SMS fallback) ───────────────────────────────────────────────────
INFOBIP_API_KEY=
INFOBIP_API_BASE_URL=

# ─── Resend (email notifications & auth) ──────────────────────────────────────
# Sign up free at https://resend.com — 3,000 emails/month free
# Note: Update the "from" address in lib/email.ts if you haven't verified noreply@amorpm.com
# You can use onboarding@resend.dev for testing without a verified domain
RESEND_API_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://amorpm.com
