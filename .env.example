# ─── Demo mode ───────────────────────────────────────────────────────────────
# Set to "true" to run without Supabase or Twilio.
# Uses in-memory data (resets on server restart). Visit /demo to preview.
NEXT_PUBLIC_DEMO_MODE=true

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://amorpm.com
