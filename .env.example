# ─── Demo mode ───────────────────────────────────────────────────────────────
# Set to "true" to run without Supabase or Resend.
# Uses in-memory data (resets on server restart). Visit /demo to preview.
NEXT_PUBLIC_DEMO_MODE=true

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://amorpm.com

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Single webhook secret — we use one consolidated endpoint in prompt 4
STRIPE_WEBHOOK_SECRET=
# Percent of each invoice the platform keeps (integer or decimal: "5" = 5%)
STRIPE_APPLICATION_FEE_PERCENT=5

# ─── Cron ─────────────────────────────────────────────────────────────────────
CRON_SECRET=
